{
  "env": { "browser": true, "es2021": true },
  "parserOptions": { "ecmaVersion": "latest" },
  "rules": {
    "no-unused-vars": "warn",
    "no-undef": "warn",
    "eqeqeq": "warn",
    "no-var": "warn"
  },
  "globals": {
    "Chart": "readonly",
    "C": "readonly",
    "createChart": "readonly",
    "animateValue": "readonly"
  }
}
